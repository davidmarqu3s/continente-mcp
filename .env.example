# continente-mcp environment variables
# Copy this to .env or set in your shell / launchd / systemd unit.

# Path where cookies are stored (default: ~/.continente/cookies.json)
# CONTINENTE_COOKIES_PATH=~/.continente/cookies.json

# If you run the MCP server on a second machine and sync cookies via a shared
# folder (e.g. Obsidian vault, Syncthing, Dropbox), set this to the shared path
# on the machine that runs the cookie reader. The reader will write cookies to
# both the default path and this one whenever it runs.
# CONTINENTE_VAULT_COOKIE_PATH=/path/to/shared/folder/cookies.json

# Override the state directory (preferences, backups)
# CONTINENTE_STATE_DIR=~/.continente
