<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.david.continente-cookie-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/D/Documents/GitHub/continente-mcp/continente-cookie-reader.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/continente-cookie-sync.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/continente-cookie-sync.err</string>
    <key>StartInterval</key>
    <!-- Run every 30 minutes -->
    <integer>1800</integer>
</dict>
</plist>
